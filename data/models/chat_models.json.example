{
  "_comment": "复制为 chat_models.json 并填写 api_key。也可仅用环境变量 LLM_API_KEY / LLM_BASE_URL / LLM_MODEL",
  "default": {
    "provider": "deepseek",
    "model": "deepseek-chat"
  },
  "fallback": {
    "provider": "openai",
    "model": "gpt-4o-mini"
  },
  "models": {
    "deepseek": {
      "description": "DeepSeek",
      "base_url": "https://api.deepseek.com/v1",
      "api_key": "",
      "is_valid": 1,
      "instances": {
        "deepseek-chat": {
          "description": "DeepSeek Chat",
          "max_tokens": 8192
        }
      }
    },
    "openai": {
      "description": "OpenAI",
      "base_url": "https://api.openai.com/v1",
      "api_key": "",
      "is_valid": 0,
      "instances": {
        "gpt-4o-mini": {
          "description": "GPT-4o Mini",
          "max_tokens": 4096
        }
      }
    }
  }
}
