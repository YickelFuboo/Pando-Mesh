    "edges": [
      { "from": "START", "to": "step_scope_refine", "condition": "always" },
      { "from": "step_scope_refine", "to": "step_codegen", "condition": "always" },
      { "from": "step_codegen", "to": "step_code_qc", "condition": "always" },
      { "from": "step_code_qc", "to": "step_ut_generate", "condition": "pass" },
      { "from": "step_code_qc", "to": "step_codegen", "condition": "reject" },
      { "from": "step_ut_generate", "to": "step_ut_execute", "condition": "always" },
      { "from": "step_ut_execute", "to": "gate_delivery", "condition": "pass" },
      { "from": "step_ut_execute", "to": "step_ut_generate", "condition": "reject" },
      { "from": "gate_delivery", "to": "END", "condition": "pass" },
      { "from": "gate_delivery", "to": "step_codegen", "condition": "reject" }
    ]
