{
  "template_id": "tpl_sr_to_ar",
  "name": "SR 架构分析",
  "description": "基于 SR 变更说明进行架构影响、接口契约与逻辑流设计；支持 {sr_id}/{sr_doc} 占位符用于并行 Lane 展开（Workspace: skills/ 目录）",
  "user_goal": "对 {requirement_id} 的 {sr_id} 完成架构元素影响分析并生成 AR 与实现设计",
  "judge_mode": "auto",
  "graph": {
    "nodes": [
      {
        "id": "step_arch_impact",
        "label": "架构影响域分析",
        "task": "请使用 {workspace}/skills/04-fwd-arch-impact-analysis 这个 skill，基于 {sr_id} 的 SR 变更说明（{sr_doc}）分析架构元素影响并生成 AR 变更文档",
        "max_iterations": 3,
        "executor": {
          "kind": "cli",
          "registered_agent_id": "claude_code",
          "cli": {
            "input": "arg",
            "cwd": "{workspace}",
            "timeout_sec": 3600,
            "env": {},
            "output_mode": "json",
            "result_json_key": "result",
            "session": {
              "enabled": true,
              "resume_args": [
                "--resume",
                "{cli_session_id}"
              ],
              "read_session_id_from_json": true,
              "session_id_json_key": "session_id",
              "history": {
                "provider": "claude_code_jsonl",
                "config_dir": "~/.claude"
              }
            },
            "commands": [
              {
                "command": "claude",
                "args": [
                  "-p",
                  "--output-format",
                  "json",
                  "--dangerously-skip-permissions",
                  "--disallowedTools",
                  "AskUserQuestion"
                ]
              }
            ]
          }
        },
        "phase": "设计",
        "node_role": "execute",
        "input_doc_paths": [
          "requirements/{requirement_id}/需求分析.md",
          "{sr_doc}",
          "requirements/{requirement_id}/feature_changes/继承性分析报告.md",
          "architectures/{*}/{*}"
        ],
        "output_doc_paths": [
          "requirements/{requirement_id}/architecture_changes/{sr_id}/{*}.md"
        ]
      },
      {
