    "edges": [
      {
        "from": "START",
        "to": "step_arch_impact",
        "condition": "always"
      },
      {
        "from": "step_arch_impact",
        "to": "step_interface",
        "condition": "always"
      },
      {
        "from": "step_interface",
        "to": "step_logic_design",
        "condition": "always"
      },
      {
        "from": "step_logic_design",
        "to": "step_arch_qc",
        "condition": "always"
      },
      {
        "from": "step_arch_qc",
        "to": "gate_ar_confirm",
        "condition": "pass"
      },
      {
        "from": "step_arch_qc",
        "to": "step_arch_impact",
        "condition": "reject"
      },
      {
        "from": "gate_ar_confirm",
        "to": "END",
