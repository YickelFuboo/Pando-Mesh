{
  "template_id": "tpl_rev_repo",
  "name": "存量逆向·代码仓",
  "description": "存量产品初始化：逆向生成各代码仓 .agent 规格/设计、DT 框架与编码规则（Workspace: skills/rev-* 目录）",
  "user_goal": "对 {workspace} 下 repos/ 各代码仓完成实现视角逆向，产出 spec/design/interfaces、DTFrame 与 rules",
  "judge_mode": "auto",
  "graph": {
    "entry": "step_repo_spec_design",
    "nodes": [
      {
        "id": "step_repo_spec_design",
        "label": "仓级规格与设计逆向",
        "task": "请使用 {workspace}/skills/rev-repo-to-spec-and-design 这个 skill，遍历 {workspace}/repos/ 下各代码仓，逆向生成或更新 .agent/spec.md、design.md、interfaces.md 及大型模块设计文档",
        "max_iterations": 3,
        "executor": {
          "kind": "cli",
          "registered_agent_id": "claude_code"
        },
        "phase": "逆向",
        "node_role": "execute",
        "input_doc_paths": [
          "repos/{*}/"
        ],
        "output_doc_paths": [
          "repos/{*}/.agent/spec.md",
          "repos/{*}/.agent/design.md",
          "repos/{*}/.agent/interfaces.md",
          "repos/{*}/.agent/modules/{*}/spec.md",
          "repos/{*}/.agent/modules/{*}/design.md"
        ]
      },
      {
        "id": "step_repo_dt_frame",
        "label": "DT 框架提取",
        "task": "请使用 {workspace}/skills/rev-repo-to-dt-frame 这个 skill，为 {workspace}/repos/ 各代码仓提取单元测试框架信息并生成 DTFrame.md",
        "max_iterations": 3,
        "executor": {
          "kind": "cli",
          "registered_agent_id": "claude_code"
        },
        "phase": "逆向",
        "node_role": "execute",
        "input_doc_paths": [
          "repos/{*}/.agent/spec.md",
          "repos/{*}/.agent/design.md"
        ],
        "output_doc_paths": [
          "repos/{*}/.agent/DTFrame.md"
        ]
      },
      {
        "id": "step_repo_rules",
        "label": "编码规则提取",
        "task": "请使用 {workspace}/skills/rev-repo-to-rules 这个 skill，从 {workspace}/repos/ 各代码仓源码与既有约定中提炼 rules/ 目录化编码规则",
        "max_iterations": 3,
        "executor": {
          "kind": "cli",
          "registered_agent_id": "claude_code"
        },
        "phase": "逆向",
        "node_role": "execute",
        "input_doc_paths": [
          "repos/{*}/.agent/spec.md",
          "repos/{*}/.agent/design.md",
          "repos/{*}/.agent/interfaces.md"
        ],
        "output_doc_paths": [
          "repos/{*}/.agent/rules/_index.md",
          "repos/{*}/.agent/rules/{*}/{*}.md"
        ]
      },
      {
        "id": "step_repo_artifact_verify",
        "label": "仓级产物校验",
        "task": "请使用 {workspace}/skills/qa-artifact-auto-verify 这个 skill，校验各代码仓 .agent 产物的格式、引用完整性与三文件接口一致性",
        "max_iterations": 3,
        "executor": {
          "kind": "cli",
          "registered_agent_id": "claude_code"
        },
        "phase": "逆向",
        "node_role": "check",
        "input_doc_paths": [
          "repos/{*}/.agent/spec.md",
          "repos/{*}/.agent/design.md",
          "repos/{*}/.agent/interfaces.md",
          "repos/{*}/.agent/DTFrame.md"
        ]
      },
      {
        "id": "gate_repo_rev_confirm",
        "label": "代码仓逆向确认",
        "task": "请确认各代码仓 .agent 文档、DTFrame 与 rules 是否可用于后续架构/业务逆向；通过后请切换模板 tpl_rev_arch",
        "max_iterations": 3,
        "executor": {
          "kind": "human"
        },
        "phase": "逆向",
        "node_role": "execute"
      }
    ],
    "edges": [
      {
        "from": "START",
        "to": "step_repo_spec_design",
        "condition": "always"
      },
      {
        "from": "step_repo_spec_design",
        "to": "step_repo_dt_frame",
        "condition": "always"
      },
      {
        "from": "step_repo_dt_frame",
        "to": "step_repo_rules",
        "condition": "always"
      },
      {
        "from": "step_repo_rules",
        "to": "step_repo_artifact_verify",
        "condition": "always"
      },
      {
        "from": "step_repo_artifact_verify",
        "to": "gate_repo_rev_confirm",
        "condition": "pass"
      },
      {
        "from": "step_repo_artifact_verify",
        "to": "step_repo_spec_design",
        "condition": "reject"
      },
      {
        "from": "gate_repo_rev_confirm",
        "to": "END",
        "condition": "pass"
      },
      {
        "from": "gate_repo_rev_confirm",
        "to": "step_repo_spec_design",
        "condition": "reject"
      }
    ]
  },
  "source_workflow_id": "",
  "created_at": "2026-07-04 00:00:00",
  "updated_at": "2026-07-04 15:30:00",
  "category": "逆向",
  "subject_schema": {
    "kind": "workspace",
    "granularity": "workspace"
  }
}
