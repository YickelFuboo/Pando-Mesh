{
  "agent_id": "trea_cli",
  "name": "Trea CLI",
  "kind": "trea_cli",
  "description": "Trea 命令行 Agent",
  "executor_template": {
    "kind": "cli",
    "cli": {
      "commands": [
        {
          "command": "trae",
          "args": []
        }
      ],
      "input": "stdin",
      "cwd": "{workspace}",
      "timeout_sec": 3600,
      "output_mode": "stdout",
      "session": {}
    }
  },
  "enabled": true,
  "builtin": true
}