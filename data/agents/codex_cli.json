{
  "agent_id": "codex_cli",
  "name": "Codex CLI",
  "kind": "codex_sdk",
  "description": "OpenAI Codex 命令行编码助手",
  "executor_template": {
    "kind": "cli",
    "cli": {
      "commands": [
        {
          "command": "codex",
          "args": [
            "exec",
            "--full-auto"
          ]
        }
      ],
      "input": "arg",
      "cwd": "{workspace}",
      "timeout_sec": 3600,
      "output_mode": "stdout"
    }
  },
  "enabled": false,
  "builtin": true
}