# MOMA-Developer 环境配置模板
# 首次使用：copy env.example .env  （run.bat 会自动创建）

SERVICE_HOST=0.0.0.0
SERVICE_PORT=8100
DEBUG=false
RUNTIME_DATA_DIR=./data
CORS_ORIGINS=*

# LLM（AI 建图 / Judge）
# 推荐：从 Pando-Harness 复制 data/models/chat_models.json 到本项目的 data/models/
LLM_MODELS_FILE=./data/models/chat_models.json
# chat_models.json 中 default 为主模型；fallback 为备选（主模型调用失败时按顺序重试）
# 示例： "fallback": { "provider": "deepseek", "model": "deepseek-chat" }

# 或使用环境变量直连 OpenAI 兼容 API（与 chat_models.json 二选一）
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.deepseek.com/v1

JUDGE_MODE=auto
